# Financial Control Portal - environment template
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Supabase (client-safe, exposed to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# --- Supabase (server-only, NEVER expose to the browser) ---
# Used by trusted server code / edge functions for privileged operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_APP_NAME=Financial Control Portal
NEXT_PUBLIC_APP_SUBTITLE=Internal Finance Platform
# Default display currency (GEL | USD). GEL is the product default.
NEXT_PUBLIC_DEFAULT_CURRENCY=GEL

# --- NBG FX integration (server-only) ---
NBG_FX_ENDPOINT=https://nbg.gov.ge/gw/api/ct/monetarypolicy/currencies/ka/json
